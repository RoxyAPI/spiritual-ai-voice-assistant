# RoxyAPI key (required) - get one at https://roxyapi.com/pricing
ROXYAPI_KEY=your_roxyapi_key_here

# RoxyAPI MCP base URL (optional - defaults to https://roxyapi.com/mcp)
# ROXYAPI_MCP_URL=https://roxyapi.com/mcp

# Comma-separated product slugs to enable (optional - defaults to ALL 12).
# Fewer tools means faster, more accurate tool selection by the model.
# Available slugs (all 12 RoxyAPI domains, verified live at https://roxyapi.com/api/v2/openapi.json):
#   astrology, vedic-astrology, numerology, tarot, human-design, forecast,
#   biorhythm, iching, crystals, dreams, angel-numbers, location
# Keep "location" enabled alongside any chart product so spoken birthplaces resolve to coordinates.
# Example - a focused subset:
# ROXYAPI_PRODUCTS=astrology,tarot,numerology,location

# LLM Provider - choose one: gemini (default), anthropic, openai
LLM_PROVIDER=gemini

# Google Gemini (default - cheapest, has free tier)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# Anthropic Claude (best quality interpretations)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT (most popular)
# OPENAI_API_KEY=your_openai_api_key_here

# Restrict which sites may embed the voice widget (optional).
# Space- or comma-separated origins; omit to allow embedding anywhere.
# WIDGET_ALLOWED_ORIGINS=https://yoursite.com,https://www.yoursite.com
